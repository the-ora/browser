#!/bin/bash
set -e

if ! command -v swiftformat >/dev/null 2>&1; then
    echo "error: swiftformat not installed. Run ./scripts/setup.sh" >&2
    exit 1
fi

if ! command -v swiftlint >/dev/null 2>&1; then
    echo "error: swiftlint not installed. Run ./scripts/setup.sh" >&2
    exit 1
fi

echo "Running SwiftFormat..."
swiftformat . --quiet

echo "Running SwiftLint..."
swiftlint lint --fix --strict

# Re-stage files modified by formatters
git add -u

echo "Pre-commit checks passed."
